{{!
    @template block_guidance/suggestion

    Renders the single top activity suggestion card.

    Context variables required for this template:
    * hassuggestion - bool
    * modnamedisplay - string
    * name - string
    * rationale - string
    * signal - string
    * clickurl - string
    * ruleid - int

    Example context (json):
    {
        "hassuggestion": true,
        "modnamedisplay": "Quiz",
        "name": "Check your understanding",
        "rationale": "Students have plenty to read but nothing to check their understanding.",
        "signal": "gap",
        "clickurl": "https://example.com/course/modedit.php",
        "ruleid": 13
    }
}}
{{#hassuggestion}}
<div class="guidance-card">
    <p class="guidance-rationale mb-2">{{rationale}}</p>
    <div class="d-flex align-items-center justify-content-between">
        {{#ischooser}}
        <a href="{{clickurl}}" class="btn btn-primary btn-sm" data-action="guidance-chooser">
            {{#str}}addsuggested, block_guidance, {{modnamedisplay}}{{/str}}
        </a>
        {{/ischooser}}
        {{^ischooser}}
        <a href="{{clickurl}}" class="btn btn-primary btn-sm">
            {{#str}}addsuggested, block_guidance, {{modnamedisplay}}{{/str}}
        </a>
        {{/ischooser}}
        <button type="button" class="btn btn-icon btn-link p-1" data-action="dismiss" data-ruleid="{{ruleid}}"
                title="{{#str}}dismiss, block_guidance{{/str}}"
                aria-label="{{#str}}dismiss, block_guidance{{/str}}">
            {{#pix}}t/down, core, {{#str}}dismiss, block_guidance{{/str}}{{/pix}}
        </button>
    </div>
</div>
{{/hassuggestion}}
{{^hassuggestion}}
<p class="text-muted mb-0">{{#str}}nosuggestion, block_guidance{{/str}}</p>
{{/hassuggestion}}
{{#hasdismissals}}
<div class="guidance-reset mt-2">
    <button type="button" class="btn btn-link btn-sm p-0" data-action="reset">
        {{#pix}}t/reset, core{{/pix}} {{#str}}resetdismissed, block_guidance{{/str}}
    </button>
</div>
{{/hasdismissals}}
