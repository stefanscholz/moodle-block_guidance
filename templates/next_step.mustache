{{!
    @template block_guidance/next_step

    Recommended next step card.

    Context variables required for this template:
    * heading - Eyebrow label above the title.
    * title - Short recommendation title.
    * rationale - One or two sentences explaining the recommendation.
    * iconurl - Activity icon URL.
    * ctaurl - Deep-link into the guidance chooser at a specific node.
    * ctalabel - Call-to-action button label.

    Example context (json):
    {
        "heading": "Recommended next step",
        "title": "Add a diagnostic quiz",
        "rationale": "Your course has no activities yet.",
        "iconurl": "https://example.com/quiz.svg",
        "ctaurl": "https://example.com/chooser.php?courseid=2&node=r_quiz",
        "ctalabel": "Set this up"
    }
}}
<div class="block-guidance-nextstep">
    <div class="block-guidance-nextstep-header">
        <img src="{{iconurl}}" alt="" aria-hidden="true" class="block-guidance-icon">
        <span class="block-guidance-eyebrow">{{heading}}</span>
    </div>
    <h4 class="block-guidance-title">{{title}}</h4>
    <p class="block-guidance-rationale">{{rationale}}</p>
    <a href="{{ctaurl}}" class="btn btn-primary block-guidance-cta">{{ctalabel}}</a>
</div>
